// Raise stepper state
let G_raise=0; // chips player will put IN this action
let G_raiseMin=0,G_raiseMax=0;

function initRaise(){
  const s=G.seats[HUMAN];
  const ca=Math.max(0,G.toCall-s.bet); // amount to call first
  // Minimum total chips to put in = call + BB (min raise is 1 BB above current bet)
  G_raiseMin=ca+BB;
  G_raiseMax=s.chips;
  G_raise=Math.min(G_raiseMin,G_raiseMax);
  updRaiseLabel();
}

// pot-fraction presets: frac = 0.5, 0.75, or 1.0
function setRaisePre(frac){
  const s=G.seats[HUMAN];
  const ca=Math.max(0,G.toCall-s.bet);
  // Pot-sized raise = call + frac*(pot after calling)
  const potAfterCall=G.pot+ca;
  const raiseBy=Math.round(potAfterCall*frac);
  // Total chips to put in = call + raise increment, min 1BB above call
  const total=ca+Math.max(BB,raiseBy);
  G_raise=Math.max(G_raiseMin,Math.min(G_raiseMax,total));
  updRaiseLabel();
}

// Fine nudge ±1 BB
function stepRaise(dir){
  const delta=dir==='up'?BB:-BB;
  G_raise=Math.max(G_raiseMin,Math.min(G_raiseMax,G_raise+delta));
  updRaiseLabel();
}

function updRaiseLabel(){
  const s=G.seats[HUMAN];
  const ca=Math.max(0,G.toCall-s.bet);
  const verb=ca===0?'BET':'RAISE TO';
  document.getElementById('ramt').textContent=verb+' '+fmt(s.bet+G_raise);
  document.getElementById('rbetbtn').textContent=ca===0?'BET ✓':'RAISE ✓';
}
