<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>POKER</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cinzel:wght@400;600;700&family=Lato:wght@300;400;700&family=Pacifico&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --gold:#c9a84c;--gl:#e8c96a;--gd:#7a5a18;
  --felt:#2d9e5f;--felt2:#228c4e;--felt3:#186636;
  --rail:#5a2d0c;--rail2:#3d1e08;--rail3:#7a3f12;
  --bgt:#003f8a;
  --tx:#f5efe0;--dim:#a07840;
  --red:#e63946;
}
html,body{width:100%;height:100%;overflow:hidden;background:#080f09;font-family:'Lato',sans-serif;color:var(--tx);user-select:none;}

/* ─── ROOM ─── */
#room{
  width:100vw;height:100vh;display:flex;flex-direction:column;
  background:radial-gradient(ellipse 130% 100% at 50% 55%,#111d13 0%,#06100a 100%);
  position:relative;
}
#room::before{content:'';position:absolute;inset:0;pointer-events:none;opacity:.3;
  background:repeating-linear-gradient(60deg,transparent,transparent 44px,rgba(255,255,255,.018) 44px,rgba(255,255,255,.018) 45px),
             repeating-linear-gradient(-60deg,transparent,transparent 44px,rgba(255,255,255,.018) 44px,rgba(255,255,255,.018) 45px);}

/* ─── HEADER ─── */
#hdr{
  display:flex;align-items:center;justify-content:space-between;
  padding:6px 16px;flex-shrink:0;z-index:20;position:relative;
  background:linear-gradient(180deg,rgba(0,0,0,.65) 0%,rgba(0,0,0,.25) 100%);
  border-bottom:1px solid rgba(201,168,76,.2);
}
.flag-sm{width:46px;height:29px;display:flex;border-radius:3px;overflow:hidden;border:1px solid var(--gd);box-shadow:0 2px 8px rgba(0,0,0,.5);}
.fb{background:var(--bgt);flex:1;}.fw{background:#eee;flex:1;display:flex;align-items:center;justify-content:center;}
.fw svg{width:17px;height:17px;}
#hdr h1{
  font-family:'Pacifico',cursive;
  font-size:1.5rem;
  color:#7dd8f8;
  letter-spacing:3px;
  text-shadow:0 0 18px rgba(100,210,255,.55), 0 2px 8px rgba(0,80,140,.6);
  line-height:1;
}
#hdr h2{font-family:'Cinzel',serif;font-size:.5rem;color:var(--dim);letter-spacing:3px;margin-top:2px;}
#hdr-l{display:flex;align-items:center;gap:10px;}
#hdr-r{display:flex;align-items:center;gap:8px;}
.hbtn{font-family:'Cinzel',serif;font-size:.62rem;letter-spacing:1px;padding:5px 11px;
  background:rgba(201,168,76,.1);border:1px solid var(--gd);color:var(--gold);
  border-radius:3px;cursor:pointer;transition:.2s;}
.hbtn:hover{background:var(--gd);}
#sbtn{background:none;border:none;color:var(--gold);font-size:1rem;cursor:pointer;padding:2px 5px;}

/* ─── MAIN ─── */
#main{flex:1;display:flex;min-height:0;position:relative;}

/* ─── TABLE AREA ─── */
#tarea{flex:1;display:flex;align-items:center;justify-content:center;position:relative;min-height:0;overflow:visible;}

/* ─── TABLE WRAP — 8-max with room for top seat ─── */
#twrap{
  position:relative;
  width:min(900px,96vw);
  /* Extra vertical space: padding-top pushes table down so top seat has room */
  height:min(560px,62vw);
  padding-top:48px;      /* space for top seat box above rail */
  padding-bottom:8px;
  box-sizing:border-box;
}

/* SVG fills the wrap */
#tsvg{position:absolute;inset:0;width:100%;height:100%;overflow:visible;}

/* ════ SEATS — WPT Gold 8-max style ════ */
.seat{
  position:absolute;transform:translate(-50%,-50%);
  width:140px;z-index:15;
}
.seat:hover{z-index:150;}

/* Main seat panel — dark pill matching WPT Gold aesthetic */
.sbox{
  width:100%;
  background:linear-gradient(160deg,#0d1f14 0%,#081208 100%);
  border:1.5px solid rgba(255,255,255,.10);
  border-radius:36px;
  padding:5px 10px 5px 5px;
  display:flex;flex-direction:row;align-items:center;gap:7px;
  position:relative;
  box-shadow:
    0 6px 24px rgba(0,0,0,.8),
    0 1px 0 rgba(255,255,255,.05) inset,
    0 -1px 0 rgba(0,0,0,.4) inset;
  transition:border-color .18s,box-shadow .18s;
  cursor:default;
}
/* YOU — cyan accent */
.sbox.you{
  border-color:rgba(80,200,255,.5) !important;
  background:linear-gradient(160deg,#0a1f22 0%,#061318 100%);
  box-shadow:0 0 20px rgba(80,200,255,.18),0 6px 24px rgba(0,0,0,.8);
}
/* Active turn — bright gold pulse */
.seat.active .sbox{
  border-color:rgba(255,200,40,.85);
  box-shadow:0 0 0 3px rgba(255,200,40,.15),0 6px 24px rgba(0,0,0,.8);
  animation:activePulse 1.4s ease-in-out infinite;
}
@keyframes activePulse{
  0%,100%{box-shadow:0 0 0 3px rgba(255,200,40,.12),0 6px 24px rgba(0,0,0,.8);}
  50%   {box-shadow:0 0 0 6px rgba(255,200,40,.22),0 6px 24px rgba(0,0,0,.8);}
}
.seat.folded .sbox{opacity:.28;filter:grayscale(1);}
.seat.winner .sbox{
  border-color:rgba(80,220,120,.9);
  box-shadow:0 0 28px rgba(80,220,120,.4),0 6px 24px rgba(0,0,0,.8);
}
.seat.bust .sbox{opacity:.14;filter:grayscale(1);}

/* Avatar circle — WPT Gold style: coloured ring shows status */
.savatar{
  width:40px;height:40px;border-radius:50%;
  background:radial-gradient(circle at 38% 35%,#2a5c38,#0f2818);
  border:2.5px solid rgba(255,255,255,.15);
  display:flex;align-items:center;justify-content:center;
  font-size:1.2rem;flex-shrink:0;
  box-shadow:0 0 0 1px rgba(0,0,0,.6);
  transition:border-color .18s;
}
.seat.active .savatar{border-color:#ffc828;}
.seat.human .savatar{border-color:rgba(80,200,255,.6);}
.seat.winner .savatar{border-color:#50dc78;}

/* Text info: name top, stack bottom */
.sinfo{
  display:flex;flex-direction:column;flex:1;min-width:0;gap:2px;
}
.sname{
  font-family:'Cinzel',serif;font-size:.50rem;font-weight:600;
  color:rgba(235,235,235,.9);letter-spacing:.4px;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
  line-height:1.2;
}
.seat.human .sname em{color:#50c8ff;font-style:normal;font-weight:700;}
.sstack{
  font-family:'Cinzel',serif;font-size:.60rem;font-weight:700;
  color:#f5c842;letter-spacing:.3px;line-height:1.1;
}

/* Face-down hole cards (bots) */
.shole{display:flex;gap:2px;margin-top:1px;}

/* Role/status badge — SB · BB · ALL IN · FOLD */
.spip{
  position:absolute;bottom:-9px;left:50%;transform:translateX(-50%);
  font-family:'Cinzel',serif;font-size:.38rem;font-weight:700;
  color:#fff;padding:1px 6px;border-radius:4px;
  white-space:nowrap;z-index:6;letter-spacing:.5px;
  box-shadow:0 1px 4px rgba(0,0,0,.6);
}
.spip.allin{background:linear-gradient(90deg,#6b21a8,#9333ea);}
.spip.fold {background:rgba(40,40,40,.95);color:rgba(255,255,255,.4);}
.spip.sbl  {background:linear-gradient(90deg,#166534,#16a34a);color:#bbf7d0;}

/* ═══ WPT Gold Dealer Button ═══
   White disc, bold D, slight 3-D bevel — matches WPT exactly */
.dbtn{
  position:absolute;top:-12px;right:-8px;
  width:22px;height:22px;border-radius:50%;
  background:radial-gradient(circle at 38% 32%,#ffffff 0%,#e0e0e0 55%,#c0c0c0 100%);
  border:2px solid #888;
  color:#111;font-size:.60rem;font-weight:900;
  font-family:'Arial Black','Arial',sans-serif;
  display:flex;align-items:center;justify-content:center;
  box-shadow:
    0 3px 10px rgba(0,0,0,.75),
    inset 0 1px 2px rgba(255,255,255,.9),
    inset 0 -1px 2px rgba(0,0,0,.2);
  letter-spacing:-1px;line-height:1;z-index:25;
}

/* Bet amount chip — floats above seat toward pot, WPT chip style */
.sbet{
  position:absolute;top:-26px;left:50%;transform:translateX(-50%);
  background:radial-gradient(circle at 40% 35%,#1a7a28,#0c4416);
  border:1.5px solid rgba(100,220,80,.5);
  color:#d4f5c0;font-family:'Cinzel',serif;
  font-size:.48rem;font-weight:700;letter-spacing:.3px;
  padding:2px 8px;border-radius:12px;white-space:nowrap;
  opacity:0;transition:opacity .18s;pointer-events:none;
  box-shadow:0 2px 10px rgba(0,0,0,.65);
}
.sbet.show{opacity:1;}

/* Countdown bar — slim line at bottom of pill */
.stimer{
  position:absolute;bottom:0;left:8px;right:8px;height:2.5px;
  border-radius:0 0 36px 36px;overflow:hidden;
}
.stimerbar{
  height:100%;width:100%;
  background:linear-gradient(90deg,#22c55e,#eab308,#ef4444);
  background-size:300% 100%;background-position:0% 0%;
  transition:width .1s linear;
}

/* ─── CARDS ─── */
.card{
  border-radius:3px;background:#fff;border:1px solid #ccc;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  font-weight:800;line-height:1;flex-shrink:0;
  box-shadow:0 2px 5px rgba(0,0,0,.4);
}
.card.red{color:#c8102e;}.card.black{color:#111;}
.card.back{background:linear-gradient(135deg,var(--bgt),#0055bb);border:1px solid var(--gd);}
.card.back::after{content:'🇬🇹';font-size:.65rem;}
.card.sm{width:21px;height:30px;font-size:.46rem;}
.card.sm .cr{font-size:.44rem;}.card.sm .cs{font-size:.52rem;}
.card.md{width:38px;height:54px;font-size:.85rem;}
.card.md .cr{font-size:.78rem;}.card.md .cs{font-size:.9rem;}
.card.lg{width:54px;height:76px;font-size:1.1rem;}
.card.lg .cr{font-size:1rem;}.card.lg .cs{font-size:1.15rem;}
.card.ph{background:rgba(255,255,255,.04);border:1px dashed rgba(255,255,255,.1);box-shadow:none;}
@keyframes flip{from{transform:rotateY(90deg) scale(.7);opacity:0;}to{transform:rotateY(0) scale(1);opacity:1;}}
.card.deal{animation:flip .2s ease-out;}

/* ─── CENTER TABLE ─── */
#cinfo{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  display:flex;flex-direction:column;align-items:center;gap:5px;
  z-index:10;pointer-events:none;
}
#felt-wm{opacity:.14;display:flex;flex-direction:column;align-items:center;gap:2px;}
.flag-wm{width:60px;height:38px;display:flex;border-radius:3px;overflow:hidden;}
.flag-wm .fb{background:var(--bgt);flex:1;}
.flag-wm .fw{background:#eee;flex:1;display:flex;align-items:center;justify-content:center;}
#wm-txt{font-family:'Cinzel Decorative',serif;font-size:.42rem;color:var(--gold);letter-spacing:2px;}
#pot-wrap{display:flex;flex-direction:column;align-items:center;gap:1px;pointer-events:none;}
#pot-lbl{font-family:'Cinzel',serif;font-size:.55rem;color:var(--dim);letter-spacing:2px;}
#pot-amt{font-family:'Cinzel Decorative',serif;font-size:1rem;color:var(--gl);text-shadow:0 0 12px rgba(201,168,76,.35);}
#comm-row{display:flex;gap:4px;align-items:center;}
#street-lbl{font-family:'Cinzel',serif;font-size:.52rem;color:var(--dim);letter-spacing:3px;}

/* ─── PLAYER CARD STRIP (between table and action bar) ─── */
#player-strip{
  display:flex;flex-direction:column;align-items:center;gap:3px;
  padding:6px 0 4px;
  background:linear-gradient(180deg,rgba(0,0,0,.0),rgba(0,0,0,.45));
  flex-shrink:0;
}
#phole{display:flex;gap:10px;}
#phandname{
  font-family:'Cinzel',serif;font-size:.6rem;color:var(--gold);letter-spacing:2px;
  background:rgba(0,0,0,.6);padding:2px 10px;border-radius:3px;
  opacity:0;transition:opacity .3s;
}
#phandname.show{opacity:1;}

/* ─── PLAYER STATS PANEL (hover on player-strip) ─── */
#player-strip{position:relative;}
#my-stats{
  display:none;
  position:absolute;
  bottom:calc(100% + 6px);
  left:50%;transform:translateX(-50%);
  background:rgba(5,15,8,.97);
  border:1px solid rgba(125,216,248,.35);
  border-radius:8px;padding:9px 12px;
  width:170px;z-index:300;
  pointer-events:none;
  box-shadow:0 4px 24px rgba(0,0,0,.85);
}
#player-strip:hover #my-stats{display:block;}

/* ─── ACTION BAR ─── */
/* ════ ACTION BAR — WPT Gold style ════ */
#abar{
  flex-shrink:0;position:relative;z-index:20;
  background:linear-gradient(0deg,rgba(0,0,0,.88) 0%,rgba(5,12,8,.75) 100%);
  border-top:1px solid rgba(255,255,255,.07);
  padding:10px 16px 12px;
  display:flex;flex-direction:column;align-items:center;gap:8px;
  transition:opacity .2s;
}
#abar.off{opacity:0;pointer-events:none;visibility:hidden;}

/* Countdown timer bar — very slim, sits at very top of abar */
#gtimer{position:absolute;top:0;left:0;right:0;height:2px;background:rgba(255,255,255,.05);}
#gtimerbar{height:100%;background:linear-gradient(90deg,#22c55e,#eab308,#ef4444);width:100%;background-size:300%;transition:width .1s linear;}

/* Stack display — small, above buttons */
#myinfo{
  display:flex;align-items:center;justify-content:center;gap:10px;
  width:100%;
}
#mychips{
  font-family:'Cinzel',serif;font-size:.62rem;color:rgba(255,255,255,.55);
  letter-spacing:.5px;
}
#mychips em{font-style:normal;color:#f5c842;}
#trd{font-family:'Cinzel',serif;font-size:.62rem;color:rgba(255,255,255,.35);letter-spacing:.5px;}

/* ── WPT Gold button row ── */
#btnrow{
  display:flex;align-items:stretch;gap:8px;width:100%;max-width:520px;
}

/* Base button — tall pill, WPT proportions */
.abtn{
  font-family:'Cinzel',serif;font-size:.72rem;font-weight:700;letter-spacing:1.5px;
  padding:0 22px;height:46px;border:none;border-radius:6px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;flex-direction:column;
  gap:1px;transition:filter .12s,transform .1s;flex:1;min-width:0;
  box-shadow:0 4px 16px rgba(0,0,0,.5),inset 0 1px 0 rgba(255,255,255,.12);
  position:relative;overflow:hidden;
}
.abtn::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(180deg,rgba(255,255,255,.10) 0%,rgba(255,255,255,0) 55%);
  pointer-events:none;
}
.abtn:hover:not(:disabled){filter:brightness(1.15);transform:translateY(-1px);}
.abtn:active:not(:disabled){transform:translateY(0);filter:brightness(.95);}
.abtn:disabled{opacity:.2;cursor:not-allowed;}

/* FOLD — dark red, WPT style */
#bfold{
  background:linear-gradient(180deg,#5c1a1a,#3d0d0d);
  color:#ff6b6b;
  border-top:1px solid rgba(220,60,60,.4);
}
#bfold:hover:not(:disabled){background:linear-gradient(180deg,#7a2020,#5c1010);}

/* CHECK — teal/green */
#bcheck{
  background:linear-gradient(180deg,#0e4d2e,#083320);
  color:#4ade80;
  border-top:1px solid rgba(74,222,128,.25);
}
#bcheck:hover:not(:disabled){background:linear-gradient(180deg,#166534,#0e4d2e);}

/* CALL — WPT blue */
#bcall{
  background:linear-gradient(180deg,#0d3a6e,#081e3f);
  color:#60a5fa;
  border-top:1px solid rgba(96,165,250,.25);
}
#bcall:hover:not(:disabled){background:linear-gradient(180deg,#1e4d8c,#0d3a6e);}

/* BET/RAISE — WPT gold/orange */
#braise,#bbet{
  background:linear-gradient(180deg,#7a4a08,#4d2e04);
  color:#fbbf24;
  border-top:1px solid rgba(251,191,36,.25);
}
#braise:hover:not(:disabled),#bbet:hover:not(:disabled){
  background:linear-gradient(180deg,#9a5c0a,#7a4a08);
}

/* ALL-IN — purple */
#ballin{
  background:linear-gradient(180deg,#5b21b6,#3b0764);
  color:#c4b5fd;
  border-top:1px solid rgba(196,181,253,.25);
}
#ballin:hover:not(:disabled){background:linear-gradient(180deg,#7c3aed,#5b21b6);}

/* Sub-label under button text (e.g. amount on CALL) */
.abtn-sub{
  font-size:.52rem;letter-spacing:.5px;opacity:.75;font-weight:400;line-height:1;
}

/* ── Raise sizing row — appears above main buttons ── */
#rrow{
  display:none;align-items:center;gap:6px;
  width:100%;max-width:520px;
}
#rrow.open{display:flex;}

/* Preset fraction chips — pill buttons */
.rstep{
  height:30px;border-radius:5px;font-size:.62rem;font-weight:700;letter-spacing:.5px;
  font-family:'Cinzel',serif;
  background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);
  color:rgba(255,255,255,.6);cursor:pointer;padding:0 10px;
  display:flex;align-items:center;justify-content:center;
  transition:.12s;white-space:nowrap;flex-shrink:0;
}
.rstep:hover{background:rgba(251,191,36,.18);border-color:rgba(251,191,36,.4);color:#fbbf24;}
.rstep:active{transform:scale(.93);}

/* −/+ nudge buttons */
.rstep.rnudge{
  width:30px;padding:0;font-size:1rem;
  background:rgba(255,255,255,.06);
}

/* Amount display */
#ramt{
  font-family:'Cinzel',serif;font-size:.78rem;font-weight:700;
  color:#fbbf24;flex:1;text-align:center;letter-spacing:.5px;
}

/* Confirm bet button */
#rbetbtn{
  height:30px;padding:0 14px;border-radius:5px;
  background:linear-gradient(180deg,#9a5c0a,#6b3f05);
  border:1px solid rgba(251,191,36,.35);
  color:#fbbf24;font-family:'Cinzel',serif;font-size:.62rem;
  font-weight:700;letter-spacing:1px;cursor:pointer;
  transition:.12s;white-space:nowrap;flex-shrink:0;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.1);
}
#rbetbtn:hover{background:linear-gradient(180deg,#b86c0c,#9a5c0a);}

/* ─── STAT TOOLTIP ─── */
.stat-tip{
  display:none;
  position:absolute;
  background:rgba(4,10,6,.97);
  border:1px solid rgba(201,168,76,.28);
  border-radius:5px;
  padding:4px 5px;
  width:96px;
  z-index:300;
  pointer-events:none;
  box-shadow:0 2px 12px rgba(0,0,0,.9);
  bottom:calc(100% + 5px);
  left:50%;
  transform:translateX(-50%);
}
/* Flip below for top seats (3,4 near dealer chair) */
.stat-tip.tip-below{
  bottom:auto;
  top:calc(100% + 6px);
}
/* Left-edge seats: anchor to left side of seat so tooltip goes rightward */
.stat-tip.tip-right{
  left:0;
  transform:none;
}
/* Right-edge seats: anchor to right side so tooltip goes leftward */
.stat-tip.tip-left{
  left:auto;
  right:0;
  transform:none;
}
.seat:hover .stat-tip{display:block;}
.stat-tip-name{
  font-family:'Cinzel',serif;font-size:.44rem;color:#e8c96a;
  letter-spacing:.3px;margin-bottom:3px;text-align:center;
  border-bottom:1px solid rgba(201,168,76,.15);padding-bottom:2px;
}
.stat-row{
  display:flex;align-items:center;justify-content:space-between;
  margin:1.5px 0;gap:3px;
}
.stat-lbl{font-family:'Cinzel',serif;font-size:.38rem;color:#666;letter-spacing:.2px;white-space:nowrap;}
.stat-val{font-family:'Cinzel',serif;font-size:.44rem;font-weight:700;color:#e8c96a;min-width:20px;text-align:right;}
.stat-bar-wrap{flex:1;height:2px;background:rgba(255,255,255,.07);border-radius:2px;overflow:hidden;}
.stat-bar{height:100%;border-radius:2px;transition:width .3s;}
.stat-bar.vpip{background:linear-gradient(90deg,#3498db,#5dade2);}
.stat-bar.pfr {background:linear-gradient(90deg,#e67e22,#f5b041);}
.stat-bar.b3  {background:linear-gradient(90deg,#8e44ad,#bb8fce);}
.stat-bar.af  {background:linear-gradient(90deg,#27ae60,#58d68d);}
.stat-hands{font-family:'Cinzel',serif;font-size:.36rem;color:#3a3a3a;text-align:center;margin-top:2px;}


/* The chip circle — small, hugs the seat */

/* Dealer chip — GT flag */
.ft-dealer .ft-dealer .ft-dealer .ft-dealer .ftf-w svg{width:11px;height:11px;}

/* SB chip */
/* BB chip */

/* Tiny label next to chip */

/* ─── WAITING ROOM ─── */
#wroom{
  display:none;position:fixed;inset:0;background:rgba(0,0,0,.88);
  z-index:300;align-items:center;justify-content:center;
}
#wroom.on{display:flex;}
#wrc{
  background:linear-gradient(160deg,#0a1e0d,#122b18);
  border:2px solid rgba(201,168,76,.4);border-radius:14px;
  padding:28px 32px;width:460px;max-width:95vw;
  box-shadow:0 0 80px rgba(0,0,0,.95);
  display:flex;flex-direction:column;align-items:center;gap:14px;
}
#wr-flag{
  width:56px;height:36px;display:flex;border-radius:4px;overflow:hidden;
  border:1px solid rgba(201,168,76,.4);box-shadow:0 2px 10px rgba(0,0,0,.5);
}
#wr-flag .fb{background:#003f8a;flex:1;}
#wr-flag .fw{background:#f0f0f0;flex:1;display:flex;align-items:center;justify-content:center;}
