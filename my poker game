function newHand(){
  if(G.autoTmr){clearInterval(G.autoTmr);G.autoTmr=null;}
  document.getElementById('adt').classList.remove('show');
  stopTmr();closeOv();clearFeltTokens();
  const ps=G.seats[HUMAN];
  if(!ps||ps.chips<=0){showBuyIn();return;}
  G.seats.forEach(s=>{if(!s.isH&&s.chips<=0)s.chips=10000;});
  G.deck=shuf(mkDk());G.comm=[];G.pot=0;G.phase='pre';G.handOver=false;
  G.toCall=BB;G.minRaise=BB;
  G.seats.forEach(s=>{
    s.bet=0;s.hole=[];s.folded=false;s.allin=false;s.active=false;
    // Per-hand stat flags
    s._vpipThisHand=false;s._pfrThisHand=false;
    s._threeBetOppThisHand=false;s._threeBetThisHand=false;
    s._cbetOppThisHand=false;s._cbetThisHand=false;
    s._facedCbetThisHand=false;s._postFlopActed=false;
    // Clear card cache so updPlayer always re-renders on new hand
    if(s.i===HUMAN){const ph=document.getElementById('phole');if(ph)ph.dataset.last='';}
  });
  do{G.dealer=(G.dealer+1)%SEATS;}while(G.seats[G.dealer].chips<=0);
  G.seats.forEach(s=>{if(s.chips>0){s.hole=[G.deck.pop(),G.deck.pop()];s.handsDealt++;}});
  const sbI=(G.dealer+1)%SEATS,bbI=(G.dealer+2)%SEATS;
  postBl(sbI,SB);postBl(bbI,BB);
  // Show position tokens on felt
  placeFeltTokens(G.dealer, sbI, bbI);
  // Rebuild hole card slots on each seat for the new hand
  // Reset all seat elements for new hand
  G.seats.forEach((s,i)=>{
    const el=document.getElementById('s'+i);if(!el)return;
    el.classList.remove('winner','folded','active','bust','human');
    if(i===HUMAN){el.classList.add('human');return;} // human has no face-down cards in seat
    let hc=el.querySelector('.shole');
    if(s.chips>0){
      if(!hc){hc=document.createElement('div');hc.className='shole';hc.style.cssText='display:flex;gap:2px;margin-top:2px;';el.querySelector('.stimer').before(hc);}
      hc.innerHTML=backH('sm')+backH('sm');
    } else if(hc){hc.remove();}
  });
  renderSeats();updPot();enAct(false);closeRaise();SND.deal();
  chat('sys',`🃏 New hand — Dealer: ${G.seats[G.dealer].name} | Blinds: ${SB}/${BB}`);
  setLog(`New hand. Dealer: ${G.seats[G.dealer].name}`);
  setTimeout(()=>startBet((bbI+1)%SEATS),500);
}
function postBl(i,a){const s=G.seats[i];const v=Math.min(a,s.chips);s.chips-=v;s.bet=v;G.pot+=v;}

// ════════════════════════════ BETTING ROUNDS ════════════════════════════
const inHand=()=>G.seats.map((_,i)=>i).filter(i=>!G.seats[i].folded&&G.seats[i].hole.length);
const canAct2=()=>G.seats.map((_,i)=>i).filter(i=>!G.seats[i].folded&&!G.seats[i].allin&&G.seats[i].chips>0&&G.seats[i].hole.length);

function startBet(from){
  if(inHand().length<=1){endHand();return;}
  G.bQ=[];
  for(let step=0;step<SEATS;step++){
    const i=(from+step)%SEATS;const s=G.seats[i];
    if(!s.folded&&!s.allin&&s.chips>0&&s.hole.length)G.bQ.push(i);
  }
  G.bPos=0;nextTurn();
}

function nextTurn(){
  if(inHand().length<=1){endHand();return;}
  if(G.bPos>0){
    const ca=canAct2();const allMat=ca.every(i=>G.seats[i].bet>=G.toCall);
    if(allMat&&G.bPos>=G.bQ.length){endBet();return;}
    if(G.bPos>=G.bQ.length){endBet();return;}
  }
  if(G.bPos>=G.bQ.length){endBet();return;}
  const idx=G.bQ[G.bPos];const s=G.seats[idx];
  G.seats.forEach(x=>x.active=false);s.active=true;renderSeats();
  if(s.isH){
    enAct(true);startTmr(()=>pAct('check'));
    setLog(`Your turn — to call: ${Math.max(0,G.toCall-s.bet)}`);
  } else {
    enAct(false);startSeatTmr(idx);
    setLog(`${s.name} is thinking…`);
    setTimeout(()=>botTurn(idx),650+Math.random()*950);
  }
}

function pAct(type,amt=0){
  if(G.handOver)return;
  stopTmr();enAct(false);closeRaise();
  applyAct(HUMAN,type,amt);G.bPos++;
  setTimeout(nextTurn,250);
}



// ════════════════════════════ BOT PERSONALITIES ════════════════════════════
// TAG=tight-aggressive  LAG=loose-aggressive  GTO=balanced
// MANIAC=ultra-aggressive  NIT=tight-passive
// Shuffle an array in place using crypto RNG
function shuffleArr(a){
  const buf=new Uint32Array(a.length);
  crypto.getRandomValues(buf);
  for(let i=a.length-1;i>0;i--){const j=buf[i]%(i+1);[a[i],a[j]]=[a[j],a[i]];}
  return a;
}

// 7 personalities for 8-handed (bots 1-7), one per seat, shuffled each session
const _allStyles=['TAG','LAG','GTO','MANIAC','NIT','TAG','LAG'];
const BOT_STYLES=shuffleArr([..._allStyles]);

// 6-max profiles — higher vpip/pfr/cbet, tighter f3b (defend more), more bluff freq
const STYLE_PROFILE={
  TAG:   {vpip:.36,pfr:.28,b3:.10,cbet:.78,f3b:.45,bluff:.22},
  LAG:   {vpip:.50,pfr:.40,b3:.18,cbet:.86,f3b:.28,bluff:.36},
  GTO:   {vpip:.42,pfr:.34,b3:.14,cbet:.72,f3b:.36,bluff:.26},
  MANIAC:{vpip:.65,pfr:.55,b3:.30,cbet:.94,f3b:.14,bluff:.50},
  NIT:   {vpip:.24,pfr:.18,b3:.06,cbet:.62,f3b:.60,bluff:.10},
};


// ════════════════════════════════════════════════════════════════
// BOT AI — GTO/Exploitative with position awareness
// ════════════════════════════════════════════════════════════════

// ── Hand strength score 0–1 (pre + post flop) ──
function botStr(idx){
  const s=G.seats[idx];
  if(!s.hole||s.hole.length<2)return 0.35;
  const h=s.hole;
  const v1=cv(h[0]),v2=cv(h[1]);
  const suited=h[0].s===h[1].s;
  const hi=Math.max(v1,v2),lo=Math.min(v1,v2);
  const gap=hi-lo;

  // ── Pre-flop equity estimate ──
  if(G.comm.length===0){
    let sc=0;
    if(v1===v2){
      // Pairs: 22=0.32 → AA=0.85
      sc=0.32+((v1-2)/12)*0.53;
    } else {
      sc=(hi-2)/12*0.44+(lo-2)/12*0.18;
      if(suited) sc+=0.07;
      if(gap===1) sc+=0.09; // connectors
      else if(gap===2) sc+=0.05;
      else if(gap===3) sc+=0.02;
      if(lo>=10) sc+=0.08;  // broadway
      if(hi===14&&lo>=10) sc+=0.10; // AK/AQ/AJ/AT
      if(hi===14&&lo>=8&&suited) sc+=0.06; // A8s+
    }
    return Math.max(0,Math.min(1,sc));
  }

  // ── Post-flop: hand evaluator + draw equity ──
  const ev=evalH([...h,...G.comm]);
  // rank 0=hi-card … 9=royal. Map generously so mid-strength hands play
  const rankMap=[0.12,0.28,0.44,0.58,0.68,0.77,0.85,0.92,0.97,1.0];
  let base=rankMap[Math.min(ev.rank,9)];

  // Draw boosts on flop/turn
  if(G.comm.length<5){
    const all=[...h,...G.comm];
    const sc={};all.forEach(c=>sc[c.s]=(sc[c.s]||0)+1);
    if(Object.values(sc).some(v=>v===4)) base+=0.12; // flush draw
    const vals=[...new Set(all.map(c=>cv(c)))].sort((a,b)=>a-b);
    for(let i=0;i<=vals.length-4;i++){
      if(vals[i+3]-vals[i]===3){base+=0.09;break;} // OESD
    }
    // Gutshot
    for(let i=0;i<=vals.length-4;i++){
      if(vals[i+3]-vals[i]===4){base+=0.04;break;}
    }
  }
  const topK=(ev.k&&ev.k[0])||0;
  base+=((topK-2)/12)*0.04;
  return Math.max(0,Math.min(1,base));
}

// ── Position: 0=EP, 1=MP, 2=CO, 3=BTN, 4=SB, 5=BB ──
// 8-handed position mapping → 6 range buckets [UTG,HJ,CO,BTN,SB,BB]
// 8 seats: dealer=BTN, +1=SB, +2=BB, +3=UTG, +4=UTG+1, +5=MP, +6=HJ, +7=CO
function botPosition(idx){
  const dealer=G.dealer;
  if(idx===dealer) return 3; // BTN
  const sbI=(dealer+1)%SEATS, bbI=(dealer+2)%SEATS;
  if(idx===sbI) return 4; // SB
  if(idx===bbI) return 5; // BB
  const dist=(idx-bbI+SEATS)%SEATS; // 1=UTG,2=UTG+1,3=MP,4=HJ,5=CO
  if(dist<=2) return 0; // UTG / UTG+1 → tightest bucket
  if(dist===3) return 1; // MP → HJ bucket
  if(dist===4) return 1; // HJ
  return 2; // CO
}

// ── 6-Max open ranges — everyone plays wider than full ring ──
// Positions: [UTG, HJ, CO, BTN, SB, BB(no open)]
// 6-max GTO opens: UTG~40%, HJ~50%, CO~60%, BTN~75%, SB~55%
// Thresholds calibrated so pf>=thresh gives correct open% per position
// [UTG, HJ, CO, BTN, SB, BB]
const OPEN_RANGE={
  NIT:    [0.645,0.540,0.460,0.355,0.472,1.0],
  TAG:    [0.503,0.445,0.382,0.295,0.408,1.0],
  GTO:    [0.452,0.393,0.330,0.265,0.357,1.0],
  LAG:    [0.408,0.348,0.295,0.238,0.320,1.0],
  MANIAC: [0.340,0.295,0.248,0.178,0.273,1.0],
};
// Call range: slightly wider than open (implied odds), same direction
// [UTG, HJ, CO, BTN, SB, BB]
const CALL_RANGE={
  NIT:    [0.550,0.460,0.393,0.310,0.415,0.503],
  TAG:    [0.460,0.408,0.360,0.270,0.375,0.393],
  GTO:    [0.415,0.360,0.308,0.245,0.330,0.348],
  LAG:    [0.375,0.320,0.270,0.215,0.295,0.295],
  MANIAC: [0.310,0.270,0.225,0.165,0.250,0.238],
};
// 3-bet value threshold: pf score above which we 3-bet for value
// Derived from top N% of hands: NIT top 6%=0.74, TAG 10%=0.673, GTO 14%=0.617, LAG 18%=0.548, MANIAC 30%=0.445
// Slightly looser at BTN/SB, tighter at UTG
const TBET_RANGE={
  NIT:    [0.790,0.760,0.740,0.720,0.750,0.740],
  TAG:    [0.720,0.700,0.680,0.650,0.670,0.660],
  GTO:    [0.660,0.640,0.617,0.590,0.610,0.600],
  LAG:    [0.590,0.565,0.548,0.510,0.540,0.530],
  MANIAC: [0.490,0.465,0.445,0.410,0.440,0.430],
};

// ── Main bot decision ──
function botTurn(idx){
  if(G.handOver)return;
  stopSeatTmr(idx);
  const s=G.seats[idx];
  const style=BOT_STYLES[(idx-1)%BOT_STYLES.length];
  const Pbase=STYLE_PROFILE[style];
  // Use adapted runtime profile if available (after enough hands), else base
  const P={
    ...Pbase,
    // Adaptive values drift from base toward exploitative adjustments
    cbet: s._adaptCbet!==null ? s._adaptCbet : Pbase.cbet,
    bluff:s._adaptBluff!==null? s._adaptBluff: Pbase.bluff,
    // vpip/pfr are used for range table selection — keep near base
    // (actual range is OPEN_RANGE keyed to style string, not P.vpip directly)
  };
  const ca=Math.max(0,G.toCall-s.bet);
  const pot=Math.max(G.pot,1);
  const street=G.phase;
  const r=Math.random();
  const pos=botPosition(idx); // 0=UTG,1=HJ,2=CO,3=BTN,4=SB,5=BB
  const numActive=inHand().length;
  const isIP=(pos===3); // in position (BTN is always IP post-flop vs everyone)

  // ── Hand facts ──
  const h=s.hole;
  const v1=cv(h[0]),v2=cv(h[1]);
  const suited=h[0].s===h[1].s;
  const hi=Math.max(v1,v2),lo=Math.min(v1,v2),gap=hi-lo;
  const isPair=v1===v2, pairRank=isPair?v1:0;
  const isSC=suited&&gap<=2&&lo>=5;
  const isBroadway=lo>=10&&hi>=10;

  // ── Pre-flop equity score (0–1) ──
  // Calibrated so: AA=0.85, KK=0.80, QQ=0.76, JJ=0.72, TT=0.67, 99=0.62
  //                AKs=1.0, AKo=0.88, AQs=0.82, AQo=0.72, KQs=0.68
  //                98s=0.43, 76s=0.35, JTo=0.52, 72o=0.18
  function pfScore(){
    let sc=0;
    if(isPair){ sc=0.32+((pairRank-2)/12)*0.53; }
    else{
      sc=(hi-2)/12*0.44+(lo-2)/12*0.18;
      if(suited)sc+=0.07; if(gap===1)sc+=0.09; else if(gap===2)sc+=0.05;
      if(isBroadway)sc+=0.08; if(hi===14&&lo>=10)sc+=0.10;
      if(hi===14&&lo>=8&&suited)sc+=0.06;
      // Penalty for disconnected offsuit trash (gap>3 and not broadway)
      if(!suited&&gap>3&&!isBroadway) sc-=0.10;
      if(!suited&&gap>5) sc-=0.06; // extra penalty for very disconnected
    }
    return Math.max(0,Math.min(1,sc));
  }

  // ── Post-flop hand rank (0–9) directly, not squashed into 0-1 ──
  // rank: 0=hc 1=pair 2=2pair 3=trips 4=str8 5=flush 6=fh 7=quads 8=sf 9=royal
  function postRank(){
    if(G.comm.length===0) return -1;
    const ev=evalH([...h,...G.comm]);
    return ev.rank;
  }

  // ── Draw outs ──
  function drawOuts(){
    const all=[...h,...G.comm];
    const sc={};all.forEach(c=>sc[c.s]=(sc[c.s]||0)+1);
    const hasFD=Object.values(sc).some(v=>v>=4); // flush draw (4 of suit)
    const vals=[...new Set(all.map(c=>cv(c)))].sort((a,b)=>a-b);
    let hasOESD=false,hasGS=false;
    for(let i=0;i<=vals.length-4;i++){
      const span=vals[i+3]-vals[i];
      if(span===3)hasOESD=true;
      if(span===4)hasGS=true;
    }
    return {fd:hasFD,oesd:hasOESD,gs:hasGS};
  }

  // ── Sizing helpers ──
  function R(frac,minBB=1){
    return Math.min(s.chips, ca+Math.max(BB*minBB, Math.round(pot*frac)));
  }
  function openSz(){
    // 6-max: BTN 2.2x, SB 2.5x, CO/HJ 2.5x, UTG 3x
    const mult=pos===3?2.2:pos===4?2.5:pos<=2?2.8:2.5;
    return Math.min(s.chips, Math.round(BB*mult));
  }
  function threeBetSz(){
    const mult=isIP?3.0:4.0; // IP smaller, OOP larger
    return Math.min(s.chips, Math.max(G.toCall*mult, BB*9));
  }
  function fourBetSz(){
    return Math.min(s.chips, Math.max(G.toCall*2.3, BB*20));
  }

  let type='check', amt=0;
  const pf=pfScore();

  // ── Live opponent reads (exploit loose/tight/passive players) ──
  // Returns adjustment multiplier: >1 = play tighter/less bluff, <1 = looser/more bluff
  function oppRead(targetIdx){
    const opp=G.seats[targetIdx];
    if(!opp||opp.handsDealt<5) return {loose:false,tight:false,passive:false,aggro:false,vpip:0.40,ftc:0.50};
    const hands=opp.handsDealt;
    const liveVPIP=opp.vpipCount/hands;
    const livePFR=opp.pfrCount/hands;
    const liveB3=opp.threeBetOpp>3?opp.threeBetCount/opp.threeBetOpp:0.10;
    const liveFtc=opp.facedCbet>3?opp.foldToCbet/opp.facedCbet:0.50; // fold-to-cbet
    const liveAgg=opp.postFlopOpp>3?opp.postFlopBet/opp.postFlopOpp:0.30;
    const isLoose=liveVPIP>0.52;
    const isTight=liveVPIP<0.26;
    const isPassive=(liveVPIP-livePFR)>0.18;
    const isAggro=livePFR/Math.max(liveVPIP,0.01)>0.82;
    const foldsToCbet=liveFtc>0.68; // folds >68% to flop bets = exploitable
    return {loose:isLoose,tight:isTight,passive:isPassive,aggro:isAggro,
            vpip:liveVPIP,b3:liveB3,ftc:liveFtc,agg:liveAgg,foldsToCbet};
  }

  // Reads on the preflop opener (whoever raised)
  // In absence of specific info, use aggregate table read
  function tableRead(){
    const active=inHand().filter(i=>i!==idx);
    if(active.length===0) return {loose:false,tight:false,passive:false,aggro:false};
    // Average VPIP of active opponents
    const avg=active.reduce((s,i)=>{
      const o=G.seats[i];
      return s+(o.handsDealt>4?o.vpipCount/o.handsDealt:0.40);
    },0)/active.length;
    return {loose:avg>0.52,tight:avg<0.28,passive:false,aggro:false,avgVpip:avg};
  }

  // ══════════════════════════════════════════════════════
  // PRE-FLOP
  // ══════════════════════════════════════════════════════
  if(street==='pre'){
    const facingOpen = G.toCall > BB;
    const facing3bet = G.toCall >= BB*3.5;
    const facing4bet = G.toCall >= BB*10;
    let openThresh = OPEN_RANGE[style][pos];

    // ── Exploitative pre-flop adjustment based on table reads ──
    const tr=tableRead();
    // vs very loose table: tighten open range slightly (they call wide, more variance)
    if(tr.loose) openThresh = Math.min(openThresh+0.03, 0.75);
    // vs very tight table: loosen up and steal more
    if(tr.tight) openThresh = Math.max(openThresh-0.04, 0.12);

    if(!facingOpen){
      if(pf >= openThresh){
        type='raise'; amt=openSz();
      } else if(ca===0){
        type='check'; // BB free look
      } else {
        type='fold';
      }

    } else if(!facing3bet){
      // Facing one open — 3-bet/call/fold
      const valueTbetMin = TBET_RANGE[style][pos];
      let callMin = CALL_RANGE[style][pos];
      const P_bluff3b = P.b3;

      // Find the opener — the seat who put in the most preflop
      const opener=inHand().filter(i=>i!==idx).reduce((best,i)=>
        G.seats[i].bet>G.seats[best].bet?i:best, inHand().filter(i=>i!==idx)[0]);
      const oRead=opener!==undefined?oppRead(opener):{};

      // Exploitative: vs tight opener, fold more marginal calls; vs loose, call wider
      if(oRead.tight) callMin=Math.min(callMin+0.04, 0.55);
      if(oRead.loose) callMin=Math.max(callMin-0.04, 0.15);
      // vs passive limper (rare preflop), squeeze more
      const bluff3bAdj = oRead.passive ? P_bluff3b*2.2 : P_bluff3b*1.8;

      if(pf >= valueTbetMin){
        type='raise'; amt=threeBetSz();
      } else if(isSC && pos>=2 && r < bluff3bAdj){
        type='raise'; amt=threeBetSz();
      } else if(isPair && pairRank<=6 && pos>=3 && r < P_bluff3b*1.2){
        type='raise'; amt=threeBetSz();
      } else if(pf >= callMin){
        type='call';
      } else if(ca===0){
        type='check';
      } else {
        type='fold';
      }

    } else if(!facing4bet){
      // Facing 3-bet — defend width scales per style's f3b
      // NIT folds 60% (defends top 40%), MANIAC folds 14% (defends 86%)
      const defend3b=1-P.f3b;
      // Base call threshold: derived so each style defends correct % of all hands
      const callThresh=0.481-defend3b*0.278;
      // Extra: LAG/MANIAC also defend speculative hands (SC, pairs) vs the tighter threshold
      const specDefend=defend3b>0.65; // LAG and MANIAC defend speculative

      if(pairRank>=14){ type='raise'; amt=fourBetSz(); } // AA: always 4-bet
      else if(pairRank===13){ type=(r<0.85)?'raise':'call'; if(type==='raise')amt=fourBetSz(); } // KK
      else if(pf>=0.82&&r<0.6){ type='raise'; amt=fourBetSz(); } // QQ/AKs mixed 4-bet
      else if(pf>=0.72){ type='call'; } // JJ, AKo, AQs always call
      else if(pf>=callThresh){ type='call'; } // style-width: NIT ~top 40%, GTO ~64%, MANIAC ~86%
      // Loose styles also defend speculative holdings they have implied odds with
      else if(specDefend&&isSC&&r<defend3b*0.90){ type='call'; } // SC: LAG/MANIAC call wide
      else if(specDefend&&isPair&&pairRank>=5&&r<defend3b*0.70){ type='call'; } // small/mid pairs
      else if(isSC&&pos===3&&r<P.b3*0.5){ type='raise'; amt=fourBetSz(); } // BTN 4-bet bluff SC (all styles)
      // MANIAC calls very wide — any two cards below threshold still call at residual frequency
      else if(r<(1-P.f3b)*0.55){ type='call'; } // MANIAC: ~86% defend total → residual calls
      else { type='fold'; }

    } else {
      // Facing 4-bet — only AA/KK continue
      if(pairRank===14){ type='raise'; amt=s.chips; }
      else if(pairRank===13&&r<0.5){ type='call'; }
      else { type='fold'; }
    }
  }

  // ══════════════════════════════════════════════════════
  // POST-FLOP
  // ══════════════════════════════════════════════════════
  else {
    const rank=postRank();
    const draws=drawOuts();

    // ── Board texture: wet boards reduce c-bet freq, dry boards increase ──
    function boardTexture(){
      if(G.comm.length===0) return {wet:false,dry:true,paired:false};
      const vals=G.comm.map(c=>cv(c));
      const suits={};G.comm.forEach(c=>suits[c.s]=(suits[c.s]||0)+1);
      const maxSuit=Math.max(...Object.values(suits));
      const sorted=[...vals].sort((a,b)=>a-b);
      let connected=0;
      for(let i=0;i<sorted.length-1;i++) if(sorted[i+1]-sorted[i]<=2) connected++;
      const flushy=maxSuit>=2;
      const straightish=connected>=1;
      const paired=new Set(vals).size<vals.length;
      const wet=flushy&&straightish;
      const dry=!flushy&&!straightish;
      return {wet,dry,paired,flushy,straightish};
    }
    const board=boardTexture();

    // C-bet gate: board texture + opponent read
    const cbetGate = board.wet  ? P.cbet*0.58 :
                     board.dry  ? P.cbet*1.05 :
                                  P.cbet*0.80;

    // Live reads on all active opponents for post-flop exploitation
    const tr2=tableRead();
    // Find if any opponent folds often to cbets (fire more vs them)
    const oppsFoldToCbet=inHand().filter(i=>i!==idx).some(i=>{
      const o=oppRead(i); return o.foldsToCbet;
    });
    const oppsLoose=tr2.loose;

    // Bluff: more vs tight/fold-heavy, less vs loose callers
    const bluffAdj = oppsLoose    ? P.bluff*0.62 :
                     oppsFoldToCbet? P.bluff*1.35 :
                     tr2.tight    ? P.bluff*1.25 :
                                    P.bluff;
    // Cbet: fire more vs players who fold to cbets
    const cbetAdj  = oppsFoldToCbet? Math.min(cbetGate*1.20, P.cbet*1.05) : cbetGate;

    // Value sizing: go thinner vs loose callers (they call with worse)
    const valueAdj = oppsLoose ? 1.12 : 1.0;

    const rankEq=[0.18,0.45,0.64,0.74,0.88,0.91,0.95,0.98,0.99,1.0];
    let eq=(rank>=0)?rankEq[Math.min(rank,9)]:0.18;
    if(G.comm.length<5){
      if(draws.fd)  eq+=0.17;
      if(draws.oesd) eq+=0.15;
      else if(draws.gs) eq+=0.08;
    }
    eq=Math.min(0.99,eq);
    const mwDisc=Math.max(0,(numActive-2)*0.07);
    const adjEq=Math.max(0.05,eq-mwDisc);
    const cr=ca/Math.max(pot,1);
    const callEq=cr/(1+cr);

    if(street==='flop'){
      if(ca===0){
        if(rank>=2){
          const sz=(rank>=4?0.80:rank===3?0.70:0.60)*valueAdj;
          type='raise'; amt=R(Math.min(sz,1.0));
        } else if(rank===1 && r<cbetAdj){
          type='raise'; amt=R(isIP?0.55:0.65);
        } else if((draws.fd||draws.oesd) && r<cbetAdj*0.85){
          type='raise'; amt=R(0.55);
        } else if(rank===0 && r<bluffAdj && !board.wet){
          // Pure bluff: avoid on wet boards (likely to get raised)
          type='raise'; amt=R(0.55);
        } else {
          type='check';
        }
      } else {
        if(rank>=3){ type='raise'; amt=R(0.85); }
        else if(rank===2&&r<0.55){ type='raise'; amt=R(0.75); }
        else if(adjEq>=callEq+0.06){ type='call'; }
        else if((draws.fd||draws.oesd)&&adjEq>=callEq){ type='call'; }
        else if(rank===0&&adjEq<callEq&&r<bluffAdj*0.6){ type='raise'; amt=R(0.80); }
        else if(adjEq<callEq*0.8){ type='fold'; }
        else { type='call'; }
      }
    }

    else if(street==='turn'){
      if(ca===0){
        // Turn: more selective — only continue with good equity
        const turnGate=cbetGate*0.80; // ~20% tighter on turn
        if(rank>=3){
          type='raise'; amt=R(rank>=5?0.90:0.75);
        } else if(rank===2 && r<turnGate){
          type='raise'; amt=R(0.65);
        } else if(rank===1 && isIP && r<turnGate*0.60){
          type='raise'; amt=R(0.65);
        } else if((draws.fd||draws.oesd) && r<turnGate*0.70){
          type='raise'; amt=R(0.70);
        } else if(rank===0 && r<bluffAdj*0.45 && isIP){
          type='raise'; amt=R(0.70);
        } else {
          type='check';
        }
      } else {
        if(rank>=4){ type='raise'; amt=R(0.90); }
        else if(rank===3&&r<0.6){ type='raise'; amt=R(0.80); }
        else if(adjEq>=callEq+0.05){ type='call'; }
        else if((draws.fd||draws.oesd)&&adjEq>=callEq){ type='call'; }
        else if(rank<=1&&r<bluffAdj*0.35){ type='raise'; amt=R(0.85); }
        else if(adjEq<callEq*0.75){ type='fold'; }
        else { type=(adjEq>=callEq)?'call':'fold'; }
      }
    }

    else if(street==='river'){
      if(ca===0){
        if(rank>=4){
          type='raise'; amt=R(rank>=6?1.20:0.90);
        } else if(rank>=2 && r<P.cbet*0.65*valueAdj){
          type='raise'; amt=R(0.70);
        } else if(rank===1 && isIP && r<P.cbet*0.30){
          type='raise'; amt=R(0.50);
        } else if(rank===0 && r<bluffAdj*0.40 && isIP){
          // River bluff: only in position, not vs loose callers
          type='raise'; amt=R(0.85);
        } else {
          type='check';
        }
      } else {
        if(rank>=5){ type='raise'; amt=R(1.10); }
        else if(rank>=3&&r<0.50){ type='raise'; amt=R(0.90); }
        else if(rank>=2&&adjEq>=callEq+0.08){ type='call'; }
        else if(rank===1&&adjEq>=callEq+0.04){ type='call'; }
        else if(rank===0&&r<bluffAdj*0.28){ type='raise'; amt=R(1.00); }
        else if(adjEq<callEq){ type='fold'; }
        else { type='call'; }
      }
    }
  }

  // ── Safety ──
  if(type==='fold'&&ca===0)          type='check';
  if(type==='raise'&&amt<=ca)        type=(ca===0?'check':'call');
  if(type==='raise'&&s.chips<=0)     type=(ca===0?'check':'call');
  if(type==='call'&&ca>=s.chips)     { type='raise'; amt=s.chips; }
  if(type==='raise'&&amt>s.chips)    amt=s.chips;
  if(type==='raise'&&amt<ca+BB&&ca>0) type='call';

  applyAct(idx,type,amt);
  G.bPos++;
  setTimeout(nextTurn,260+Math.random()*360);
}



function applyAct(idx,type,rAmt=0){
  const s=G.seats[idx];const ca=Math.max(0,G.toCall-s.bet);let msg='';

  // ════ Stat tracking — feeds both HUD tooltips and self-adaptation ════
  if(G.phase==='pre'){
    if((type==='call'||type==='raise'||type==='allin')&&!s._vpipThisHand){
      s._vpipThisHand=true; s.vpipCount++;
    }
    if((type==='raise'||type==='allin')&&!s._pfrThisHand){
      s._pfrThisHand=true; s.pfrCount++;
    }
    if(G.toCall>BB){
      s._threeBetOppThisHand=true; s.threeBetOpp++;
      if(type==='raise'||type==='allin'){s._threeBetThisHand=true; s.threeBetCount++;}
    }
  }
  // Post-flop aggression tracking (bet/raise on any street)
  if(G.phase!=='pre'&&!s._postFlopActed){
    s._postFlopActed=true; s.postFlopOpp++;
    if(type==='raise'||type==='allin') s.postFlopBet++;
  }
  // C-bet and fold-to-cbet
  if(G.phase==='flop'){
    if((type==='raise'||type==='allin')&&!s._cbetOppThisHand){
      s._cbetOppThisHand=true; s.cbetOpp++;
      s._cbetThisHand=true; s.cbetCount++;
    }
    // Fold-to-cbet: bot faces a flop bet and folds
    if(ca>0&&!s._facedCbetThisHand){
      s._facedCbetThisHand=true; s.facedCbet++;
      if(type==='fold') s.foldToCbet++;
    }
  }

  // ════ Self-adaptation: every 8 hands recalibrate runtime tendencies ════
  // Bots observe their own results and tilt/adjust their effective style profile
  if(s.handsDealt>0&&s.handsDealt%8===0&&s.handsDealt>0){
    const hd=s.handsDealt;
    const myVpip=s.vpipCount/hd;
    const myPfr=s.pfrCount/hd;
    const myCbet=s.cbetOpp>2?s.cbetCount/s.cbetOpp:P.cbet;
    const myFtc=s.facedCbet>2?s.foldToCbet/s.facedCbet:P.f3b;
    const myAgg=s.postFlopOpp>3?s.postFlopBet/s.postFlopOpp:P.cbet*0.5;
    // Opponent aggregate reads for counter-adjustment
    const oppVpips=inHand().filter(i=>i!==idx).map(i=>{
      const o=G.seats[i]; return o.handsDealt>4?o.vpipCount/o.handsDealt:0.42;
    });
    const tableAvg=oppVpips.length?oppVpips.reduce((a,b)=>a+b,0)/oppVpips.length:0.42;
    // Adaptive drift rules (GTO-exploitative adjustments):
    // Rule 1: vs very loose table → tighten own VPIP toward base style
    // Rule 2: vs very tight table → loosen bluffs
    // Rule 3: if own fold-to-cbet very high → defend more (don't be exploited)
    // Rule 4: if own cbet getting raised often → slow down cbet freq
    const looseTable=tableAvg>0.55;
    const tightTable=tableAvg<0.28;
    const overFolding=myFtc>0.75; // folding to cbet >75% is too exploitable
    const underFolding=myFtc<0.20; // rarely folding means opponents fire less
    // Store adapted values (bounded within personality range)
    s._adaptVpip = Math.max(P.vpip*0.80, Math.min(P.vpip*1.20,
      looseTable ? P.vpip*0.93 : tightTable ? P.vpip*1.08 : myVpip*0.85+P.vpip*0.15));
    s._adaptBluff = Math.max(P.bluff*0.50, Math.min(P.bluff*1.60,
      tightTable ? P.bluff*1.25 : looseTable ? P.bluff*0.75 : P.bluff));
    s._adaptCbet = Math.max(P.cbet*0.55, Math.min(P.cbet*1.10,
      overFolding ? P.cbet*1.05 : underFolding ? P.cbet*0.85 : myCbet*0.5+P.cbet*0.5));
  }

  if(type==='fold'){s.folded=true;msg=`${s.name} folds.`;SND.fold();}
  else if(type==='check'){msg=`${s.name} checks.`;SND.check();}
  else if(type==='call'){
    const a=Math.min(ca,s.chips);s.chips-=a;s.bet+=a;G.pot+=a;
    if(s.chips===0)s.allin=true;msg=`${s.name} calls ${a}.`;SND.chip();
  } else if(type==='raise'){
    const wanted = rAmt > 0 ? rAmt : (ca + G.minRaise);
    const tot = Math.min(wanted, s.chips);
    const newBet = s.bet + tot;
    const raiseBy = newBet - G.toCall;
    s.chips -= tot; s.bet = newBet; G.pot += tot;
    G.toCall = newBet;
    G.minRaise = Math.max(BB, raiseBy);
    if(s.chips===0) s.allin=true;
    const others=G.bQ.slice(G.bPos+1).filter(i=>!G.seats[i].folded&&!G.seats[i].allin&&i!==idx);
    const fresh=inHand().filter(i=>!G.bQ.slice(0,G.bPos+1).includes(i)&&!G.seats[i].allin&&i!==idx);
    const re=[...others,...fresh.filter(i=>!others.includes(i))];
    if(re.length)G.bQ=[...G.bQ.slice(0,G.bPos+1),...re];
    msg=`${s.name} raises to ${s.bet}.`;SND.chip();
  } else if(type==='allin'){
    const a=s.chips;s.chips=0;s.bet+=a;G.pot+=a;s.allin=true;
    if(s.bet>G.toCall){G.toCall=s.bet;G.minRaise=Math.max(BB,a);}
    msg=`💥 ${s.name} ALL IN (${a})!`;SND.allin();
  }
  setLog(msg);if(msg)chat('sys',msg);
  renderSeats();updPot();
  if(idx!==HUMAN)refreshStatTip(idx);
}

function endBet(){
  G.seats.forEach(s=>{s.active=false;s.bet=0;});G.toCall=0;G.minRaise=BB;renderSeats();
  const ph=G.phase;
  if(ph==='pre'){G.phase='flop';setTimeout(dFlop,450);}
  else if(ph==='flop'){G.phase='turn';setTimeout(dTurn,450);}
  else if(ph==='turn'){G.phase='river';setTimeout(dRiver,450);}
  else if(ph==='river'){G.phase='showdown';setTimeout(showdown,450);}
}
function dFlop(){G.deck.pop();G.comm.push(G.deck.pop(),G.deck.pop(),G.deck.pop());SND.deal();updPot();updPlayer();chat('sys','🌊 Flop.');setTimeout(()=>startBet((G.dealer+1)%SEATS),650);}
function dTurn(){G.deck.pop();G.comm.push(G.deck.pop());SND.deal();updPot();updPlayer();chat('sys','🔄 Turn.');setTimeout(()=>startBet((G.dealer+1)%SEATS),650);}
function dRiver(){G.deck.pop();G.comm.push(G.deck.pop());SND.deal();updPot();updPlayer();chat('sys','🏁 River.');setTimeout(()=>startBet((G.dealer+1)%SEATS),650);}
function endHand(){if(inHand().length===1){G.phase='showdown';showdown();}else endBet();}

function showdown(){
  G.handOver=true;stopTmr();enAct(false);
  const ih=inHand();
  if(ih.length===1){
    const w=G.seats[ih[0]];w.chips+=G.pot;SND.win();renderSeats();updPot();
    chat('sys',`🏆 ${w.name} wins ${fmt(G.pot)} (everyone folded)!`);
    setLog(`${w.name} wins ${fmt(G.pot)}!`);
    showOv(w.isH?'🏆 YOU WIN!':'Hand Over',`${w.name} wins <b>${fmt(G.pot)}</b> chips!<br>Everyone else folded.`);
    schedNext();return;
  }
  const res=ih.map(i=>{const s=G.seats[i];return{i,seat:s,hole:s.hole,folded:s.folded,ev:evalH([...s.hole,...G.comm])};})
    .sort((a,b)=>b.ev.rank-a.ev.rank||cmpK(b.ev.k,a.ev.k));
  const top=res[0].ev;
  const wins=res.filter(r=>r.ev.rank===top.rank&&cmpK(r.ev.k,top.k)===0);
  const split=Math.floor(G.pot/wins.length);wins.forEach(w=>w.seat.chips+=split);
  SND.win();
  // Reveal cards — patch existing seat elements, don't rebuild
  res.forEach(r=>{
    if(r.i===HUMAN)return;
    const el=document.getElementById('s'+r.i);if(!el)return;
    const hc=el.querySelector('.shole');
    if(hc)hc.innerHTML=r.hole.map(c=>cardH(c,'sm')).join('');
    if(wins.find(w=>w.i===r.i))el.classList.add('winner');
  });
  renderSeats();updPot();
  const w=wins[0];
  let body=res.map(r=>`<b>${r.seat.name}</b>: ${r.ev.name}`).join('<br>');
  if(wins.length>1)body+=`<br><br>🤝 Split — ${fmt(split)} each`;
  else body+=`<br><br>🏆 <b>${w.seat.name}</b> wins <b>${fmt(G.pot)}</b> with <b>${w.ev.name}</b>!`;
  chat('sys',`🏆 ${w.seat.name} wins ${fmt(G.pot)} — ${w.ev.name}`);
  setLog(`${w.seat.name} wins with ${w.ev.name}!`);
  showOv(w.seat.isH?'🏆 YOU WIN!':'Hand Over',body);
  schedNext();
}

// ════════════════════════════ AUTO NEXT ════════════════════════════
function schedNext(){
  let cd=5;const bar=document.getElementById('adt'),cnt=document.getElementById('adc');
  cnt.textContent=cd;bar.classList.add('show');
  G.autoTmr=setInterval(()=>{cd--;cnt.textContent=cd;if(cd<=0){clearInterval(G.autoTmr);G.autoTmr=null;bar.classList.remove('show');newHand();}},1000);
}

// ════════════════════════════ OVERLAY ════════════════════════════
function showOv(title,body){document.getElementById('ovt').textContent=title;document.getElementById('ovb').innerHTML=body;document.getElementById('ov').classList.add('on');}
function closeOv(){document.getElementById('ov').classList.remove('on');}

// ════════════════════════════ BUY-IN ════════════════════════════
function showBuyIn(){document.getElementById('bm').classList.add('on');}
function closeBuyIn(){document.getElementById('bm').classList.remove('on');}
function doBuyIn(amt){
  G.seats[HUMAN].chips+=amt;SND.chip();
  document.getElementById('mychips').innerHTML=`<em>STACK </em>${fmt(G.seats[HUMAN].chips)}`;
  chat('sys',`💰 You bought in for ${fmt(amt)} chips.`);
  closeBuyIn();
  // Open the waiting room — 3 min to fill, then bots
  if(G.handOver) wrInit();
}

// ════════════════════════════ CHAT ════════════════════════════
const QUIPS=['¡Buena suerte!','Interesting…','Let\'s go!','Nice try!','I\'ve seen better bluffs.','¡Vamos Guatemala!','Calculating odds…','¡Qué mano!','Bold move.','Poker face: on.'];
function toggleChat(){
  const c=document.getElementById('chat');
  c.classList.toggle('open');
  if(c.classList.contains('open')){
    const b=document.getElementById('chat-badge');
    b.classList.remove('on');
    // scroll to bottom
    const msgs=document.getElementById('cmsgs');
    setTimeout(()=>msgs.scrollTop=msgs.scrollHeight,50);
  }
}

function chat(type,msg,name=''){
  const div=document.getElementById('cmsgs');
  // Show badge on toggle button if chat is closed
  const chatEl=document.getElementById('chat');
  if(!chatEl.classList.contains('open')&&type!=='me'){
    const b=document.getElementById('chat-badge');
    b.textContent='●';b.classList.add('on');
  }
  const el=document.createElement('div');
  if(type==='sys'){el.className='cm sys';el.textContent=msg;}
  else if(type==='me'){el.className='cm me';el.innerHTML=`<span class="cn" style="color:#7dd3fc">You:</span> ${msg}`;}
  else{el.className='cm bot';el.innerHTML=`<span class="cn">${name}:</span> ${msg}`;}
  div.appendChild(el);div.scrollTop=div.scrollHeight;
  if(type==='me'&&Math.random()<.5){
    const b=G.seats[1+~~(Math.random()*8)];
    setTimeout(()=>chat('bot',QUIPS[~~(Math.random()*QUIPS.length)],b.name),900+Math.random()*1200);
  }
}
function sendChat(){const i=document.getElementById('cin'),m=i.value.trim();if(!m)return;chat('me',m);i.value='';bp(600,.04,.06);}

// ════════════════════════════ WAITING ROOM ════════════════════════════
const WR_TOTAL = 180; // 3 minutes in seconds
let wrTimer = null, wrLeft = WR_TOTAL;

// Simulated "real players" who join during the wait — adds realism
const HUMAN_NAMES = ['Miguel','Valentina','Alejandro','Isabella','Sebastián','Camila','Andrés','Lucía'];
const HUMAN_EMOJIS = ['👨','👩','🧑','👩‍💼','👨‍💼','🧕','👱','👩‍🦰'];

// Track which seats are real humans vs bots (seat 0 = always local player)
// wrSeats[i] = null (empty), 'bot', or {name, emoji} (human)
let wrSeats = [];

function wrInit(){
  wrSeats = new Array(SEATS).fill(null);
  wrSeats[0] = {name:'You', emoji:'🫵', isLocal:true};
  document.getElementById('wroom').classList.add('on');
  wrRenderSeats();
  wrLeft = WR_TOTAL;
  wrTick();
  wrTimer = setInterval(wrTick, 1000);
  // Simulate 1–3 humans joining at random intervals during the wait
  const joinCount = 1 + Math.floor(Math.random() * 3);
  for(let k = 0; k < joinCount; k++){
    const delay = 8000 + Math.random() * 90000; // 8s–98s
    setTimeout(()=>{ if(wrTimer) wrSimJoin(); }, delay);
  }
}

function wrSimJoin(){
  // Find a random empty seat (not 0)
  const empty = [];
  for(let i=1;i<SEATS;i++) if(!wrSeats[i]) empty.push(i);
  if(!empty.length) return;
  const seat = empty[Math.floor(Math.random()*empty.length)];
  const idx = Math.floor(Math.random()*HUMAN_NAMES.length);
  wrSeats[seat] = {name: HUMAN_NAMES[idx], emoji: HUMAN_EMOJIS[idx]};
  wrRenderSeats();
  chat('sys', `🙋 ${HUMAN_NAMES[idx]} joined seat ${seat+1}!`);
  // If table full, start immediately
  if(wrSeats.every(s=>s!==null)) wrFill(false);
}

function wrRenderSeats(){
  const grid = document.getElementById('wr-seats');
  grid.innerHTML = '';
  for(let i=0;i<SEATS;i++){
    const s = wrSeats[i];
    const div = document.createElement('div');
    div.className = 'wr-seat' + (s ? (s.isLocal ? ' me' : ' taken') : '');
    div.innerHTML = s
      ? `<div class="ws-avatar">${s.emoji}</div>
         <div class="ws-name">${s.name}</div>
         <div class="ws-status">${s.isLocal ? '★ YOU' : '✓ Ready'}</div>`
      : `<div class="ws-avatar" style="opacity:.25">⬜</div>
         <div class="ws-name" style="color:#333">Empty</div>
         <div class="ws-status">—</div>`;
    grid.appendChild(div);
  }
}

function wrTick(){
  wrLeft--;
  // Update countdown display
  const m = Math.floor(wrLeft/60), s = wrLeft%60;
  document.getElementById('wr-cd-num').textContent =
    `${m}:${String(s).padStart(2,'0')}`;
  // Arc: 175.9 = circumference of r=28 circle
  const offset = 175.9 * (1 - wrLeft/WR_TOTAL);
  document.getElementById('wr-arc').style.strokeDashoffset = offset;
  // Color shift as time runs low
  if(wrLeft <= 30) document.getElementById('wr-arc').style.stroke = '#e74c3c';
  else if(wrLeft <= 60) document.getElementById('wr-arc').style.stroke = '#f39c12';
  if(wrLeft <= 0){ wrFill(true); }
}

function wrFill(fillBots){
  if(wrTimer){ clearInterval(wrTimer); wrTimer = null; }
  document.getElementById('wroom').classList.remove('on');
  // Fill remaining seats with bots
  for(let i=1;i<SEATS;i++){
    if(!wrSeats[i]) wrSeats[i] = 'bot';
  }
  // Apply real-player names/emojis to game seats
  G.seats.forEach((s,i)=>{
    if(i===0) return; // local player handled separately
    const ws = wrSeats[i];
    if(ws && ws !== 'bot'){
      s.name = ws.name;
      s.emoji = ws.emoji;
      s.isBot = false;
    } else {
      s.name = BNAMES[i-1];
      s.emoji = BEMOJIS[i-1];
      s.isBot = true;
    }
  });
  if(fillBots)
    chat('sys','⏱ Time up — bots filling empty seats. Game starting!');
  else
    chat('sys','✅ Table full! Game starting!');
  // Rebuild seat elements to reflect new names/emojis
  document.querySelectorAll('.seat').forEach(e=>e.remove());
  initSeatEls();
  // Start the hand
  setTimeout(()=>{ if(G.seats[HUMAN].chips > 0) newHand(); }, 600);
}

function wrStartNow(){
  wrLeft = 1; // let wrTick fire wrFill on next tick
  wrTick();
}

function wrCopyLink(){
  const url = window.location.href.split('?')[0] + '?table=' + Math.random().toString(36).slice(2,8).toUpperCase();
  navigator.clipboard.writeText(url).then(()=>{
    document.getElementById('wr-share-note').textContent = '✓ Link copied to clipboard!';
    setTimeout(()=>document.getElementById('wr-share-note').textContent='', 3000);
  }).catch(()=>{
    document.getElementById('wr-share-note').textContent = url;
  });
}

